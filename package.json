{
  "name": "smp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n \"API,WEB\" -c \"cyan,blue\" \"nodemon -e ts --exec tsx src/api/server.ts\" \"vite --port 5173\"",
    "dev:web": "vite --port 5173",
    "dev:api": "nodemon -e ts --exec tsx src/api/server.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "tsx src/api/server.ts",
    "lint": "eslint . --max-warnings 0",
    "deploy": "npm run build && wrangler pages deploy dist --project-name smp",
    "deploy:dry": "npm run build && wrangler pages deploy dist --project-name smp --dry-run"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "mongoose": "^8.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.0.0",
    "nodemon": "^3.1.2",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wrangler": "^4.19.0"
  }
}
